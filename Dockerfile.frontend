FROM --platform=$BUILDPLATFORM demonstrationorg/dhi-node:25-alpine3.23-sfw-dev@sha256:1f2e4cd8884627bbe365c1fbb41a8f64e01f47603ce523491680562e170d6755 AS build
COPY . /app
WORKDIR /app
RUN yarn install
RUN yarn workspace app build

FROM demonstrationorg/dhi-nginx:1.29-alpine3.23-dev_backstage@sha256:c88cc05787e2185409d16b46b495dc61c4d4ff0be11c490d34bd3cfc1c933e72
ARG UID=nginx
USER root
COPY --from=build --chown=nginx:nginx /app/packages/app/dist /usr/share/nginx/html
RUN chown -R $UID:$UID /usr/share/nginx/html/
RUN chmod -R g+w /usr/share/nginx/html/
COPY container-config/default.conf.template /etc/nginx/templates/default.conf.template
COPY container-config/inject-config.sh /docker-entrypoint.d/40-inject-config.sh
USER $UID
ENV PORT=8080
